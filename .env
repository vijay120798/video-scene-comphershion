DEVICE=cpu
# Workspace
WORKSPACE_DIR=./workspace
FRAME_INTERVAL_SEC=3.0
MAX_FRAMES=8

# Vision + LLM model: use OpenAI model ID when BASE_URL is api.openai.com (e.g. gpt-4o, gpt-4o-mini)
