# CLIP embedding model
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
DEVICE=cuda
BATCH_SIZE=8

# Retrieval
TOP_K=4
MIN_RETRIEVAL_SCORE=0.18

# Gemini (vision, chunk summarization, and final answers). Use a supported model: gemini-2.0-flash, gemini-2.0-flash-lite, etc.
GEMINI_MODEL_NAME=gemini-2.0-flash
QWEN_MODEL_NAME=gpt-4o-mini

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Offline dummy mode (no OpenAI or Gemini calls). Set to true to avoid quotas.
OFFLINE_MODE=false
